{
  "name": "jjj-vscode-extension",
  "displayName": "JJJ VS Code Extension",
  "description": "VS Code extension for task management and code review, powered by the jjj command-line tool.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:jjj-tasks"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jjj.init",
        "title": "JJJ: Initialize Repository"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jjj-sidebar-view",
          "title": "JJJ",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "jjj-sidebar-view": [
        {
          "id": "jjj-welcome",
          "name": "Welcome",
          "when": "!jjj.initialized"
        },
        {
          "id": "jjj-tasks",
          "name": "Tasks",
          "when": "jjj.initialized"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "jjj.init",
          "when": "view == jjj-welcome",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTests.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.70.0",
    "@types/glob": "^8.0.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "eslint": "^8.24.0",
    "glob": "^8.0.3",
    "mocha": "^10.1.0",
    "typescript": "^4.9.4",
    "@vscode/test-electron": "^2.2.0"
  }
}
