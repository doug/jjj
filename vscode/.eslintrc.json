{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
  "rules": {
    // Formatting is handled by Prettier, so we disable these rules
    "semi": "off",
    "quotes": "off",
    "indent": "off",
    "no-trailing-spaces": "off",
    "no-multiple-empty-lines": "off",
    "comma-dangle": "off",
    "arrow-parens": "off",
    "max-len": "off",
    // TypeScript-specific formatting rules - let Prettier handle them
    "@typescript-eslint/semi": "off",
    "@typescript-eslint/quotes": "off",
    "@typescript-eslint/indent": "off",
    "@typescript-eslint/comma-dangle": "off",
    // Keep code quality rules (non-formatting)
    "@typescript-eslint/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "@typescript-eslint/no-explicit-any": "warn",
    "no-console": "off"
  },
  "env": {
    "node": true,
    "es6": true
  },
  "ignorePatterns": ["out", "dist", "node_modules", "*.js", "*.d.ts"]
}
